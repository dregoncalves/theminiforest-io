      "textPosition": "left",
      "blockClass": "submenu-titulo"
    }
  },
  "rich-text#titulo-primeiros-meses": {
    "props": {
      "text": "PRIMEIROS MESES",
      "tag": "h4",
      "textPosition": "left",
      "blockClass": "submenu-titulo"
    }
  },

